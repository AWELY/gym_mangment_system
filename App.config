<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <connectionStrings>
        <!-- Local SQL Server (Windows Authentication). Adjust Data Source to match your instance. -->
        <add name="GymDb"
             connectionString="Data Source=.;Initial Catalog=GymDB;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
    <appSettings>
        <!-- Qonvo WhatsApp API: https://backup.qonvo.ly/api — ضع المفتاح محلياً ولا ترفعه للمستودع -->
        <add key="QonvoBaseUrl" value="https://backup.qonvo.ly/api" />
        <add key="QonvoApiToken" value="YhmV0CmIfgJAcfNFVfo7ezzulQKQgAUpDtDTRVLBUTqRcbQfJrtn26WaIVujy2b8" />
        <!-- رقم واتساب المسجّل في Qonvo والمصادق عليه (المرسل) -->
        <add key="QonvoSenderWhatsAppPhone" value="+218924907361" />
        <!-- عند إدخال رقم محلي يبدأ بـ 0 أو بدون مفتاح دولة، تُضاف هذه الدولة (218 = ليبيا) -->
        <add key="QonvoDefaultCountryCode" value="218" />
    </appSettings>
    <startup useLegacyV2RuntimeActivationPolicy="true"> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>