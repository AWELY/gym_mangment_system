<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <connectionStrings>
        <!-- Local SQL Server (Windows Authentication). Adjust Data Source to match your instance. -->
        <add name="GymDb"
             connectionString="Data Source=.;Initial Catalog=GymDB;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
    <appSettings>
        <!-- WASL (Wasel) WhatsApp API — ضع المفتاح محلياً ولا ترفعه للمستودع -->
        <add key="WaslBaseUrl" value="https://wasl.itsyosefali.cloud/api/v1" />
        <add key="WaslApiToken" value="wAfx0lpkO028wCdMXFRVHLcVcxdpQ0L5qdhxdgYDlWsurvLMH6e37dJSAQ2d" />
        <!-- رقم واتساب المسجّل على الجهاز المرسل (أرقام فقط مع مفتاح الدولة) -->
        <add key="WaslSenderPhone" value="+218910137119" />
        <!-- عند إدخال رقم محلي يبدأ بـ 0 أو بدون مفتاح دولة، تُضاف هذه الدولة (218 = ليبيا) -->
        <add key="WaslDefaultCountryCode" value="218" />
    </appSettings>
    <startup useLegacyV2RuntimeActivationPolicy="true"> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>